# MongoDB Atlas connection string
# Get this from: Atlas dashboard → your cluster → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/committee-coordinator?retryWrites=true&w=majority

# JWT secret — change this to a long random string in production
JWT_SECRET=vjti_committee_coordinator_secret_key_2024

PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slash)
# Leave empty to allow all (dev only). Set in Render for production.
FRONTEND_URL=https://your-frontend.onrender.com
